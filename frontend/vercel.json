{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://first-deployment-moq0.onrender.com/api/:path*"
    },
    {
      "source": "/static/uploads/:path*",
      "destination": "https://first-deployment-moq0.onrender.com/static/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

